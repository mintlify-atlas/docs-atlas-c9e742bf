  "keyFeatures": [
    "Email/password authentication with Firebase Auth",
    "Travel destination CRUD (create, read, update, delete)",
    "Image upload and management via Firebase Cloud Storage",
    "Real-time data sync with Cloud Firestore",
    "Material Design UI with custom purple/pink branding",
    "Country selection from a curated list of 23 destinations",
    "Auth-guarded main screen — redirects unauthenticated users to login"
  ],
  "publicApiSurface": [
    "FirebaseService.login(email, password, callback)",
    "FirebaseService.register(email, password, callback)",
    "FirebaseService.logout()",
    "FirebaseService.getCurrentUser()",
    "FirebaseService.getDestinations(callback)",
    "FirebaseService.saveDestination(destination, imageUri, callback)",
    "FirebaseService.updateDestinations(destination, imageUri, callback)",
    "FirebaseService.updateDestinationWithoutImage(destination, callback)",
    "FirebaseService.deleteDestinations(id, callback)",
    "Destination(id, name, country, price, description, imageUrl)"
  ]
